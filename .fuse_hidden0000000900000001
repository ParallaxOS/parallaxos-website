#!/bin/bash
set -e
cd /sessions/admiring-confident-bohr/mnt/outputs

# Clean up debug files from previous turns (don't ship them)
rm -f _scan.py _scan.txt _finalize.py _finalize_report.txt _repack.sh _repack_out.txt 2>/dev/null || true

# Wipe and rebuild a clean temp repo with the latest content
rm -rf /tmp/parallaxos-website
mkdir -p /tmp/parallaxos-website

rsync -a \
  --exclude='.git' \
  --exclude='.DS_Store' \
  --exclude='_preview-network-logos.png' \
  --exclude='_scan.py' --exclude='_scan.txt' \
  --exclude='_finalize.py' --exclude='_finalize_report.txt' \
  --exclude='_repack.sh' --exclude='_repack_out.txt' \
  --exclude='parallaxos-website.bundle' \
  --exclude='parallaxos-website.zip' \
  --exclude='assets/parallaxos-logo.png' \
  --exclude='assets/parallaxos-logo-still.png' \
  --exclude='assets/parallaxos-mark.png' \
  --exclude='assets/parallaxos-banner.png' \
  --exclude='assets/parallaxos-lockup.png' \
  --exclude='assets/parallaxos-lockup-transparent.png' \
  --exclude='assets/parallaxos-lockup-tx.png' \
  ./ /tmp/parallaxos-website/

cd /tmp/parallaxos-website
git init -b main --quiet
git config user.name "Aaron"
git config user.email "aaron@ajrail.com.au"

git add -A
git commit --quiet -m "Update pricing and reframe Hunter Valley claims

Pricing:
- Starter: $299 -> $599/mo (up to 5 workers)
- Professional: $599 -> $999/mo (up to 15 workers)
- ROI calculator updated (math now 3x in month one vs 5x)
- Enterprise estimate bumped to $1,999/mo for parity

Honest copy on pre-launch status:
- Hero eyebrow: 'Live on the Hunter Valley rail corridor'
  -> 'Pilot-ready for AusRail 2026'
- Hero metrics: replaced demo data implying live customers
  with platform capability claims (3 sec Avetta, 9 AI agents,
  12 networks, AASB S2)
- Testimonials: reframed as composite quotes from user
  discovery, removed specific fabricated attributions
- About page Hunter Valley story: 'live right now' ->
  'engineered against reference scenarios'
- Docs (avetta, edge-mode, ai-agents): 'Hunter Valley
  deployment/pilot' -> 'Hunter Valley reference dataset'
- features.html and index.html CTAs: 'live on real Hunter
  Valley data right now' -> 'pilot-ready, built on a
  realistic Hunter Valley reference dataset'

Marketing positioning remains Hunter Valley-focused but no
longer claims active customer deployment."

# Bundle for git remote push
git bundle create /sessions/admiring-confident-bohr/mnt/outputs/parallaxos-website.bundle main

# ZIP for GitHub Desktop drop-in
cd /tmp/parallaxos-website
rm -f /sessions/admiring-confident-bohr/mnt/outputs/parallaxos-website.zip
zip -r -q /sessions/admiring-confident-bohr/mnt/outputs/parallaxos-website.zip . -x ".git/*" -x "*.DS_Store"

# Final verification — write report
{
  echo "=== FILE COUNT ==="
  git ls-files | wc -l
  echo ""
  echo "=== KEY CHANGE VERIFICATION ==="
  echo -n "Starter \$599 present: "
  grep -c 'Starter \$599' index.html pricing.html 2>/dev/null | awk -F: '{s+=$2} END {print s}'
  echo -n "Professional \$999 present: "
  grep -c 'Professional \$999\|\$999/mo\|\$999<small>' index.html pricing.html 2>/dev/null | awk -F: '{s+=$2} END {print s}'
  echo -n "Stale \$299 references: "
  grep -rc '\$299' --include="*.html" --include="*.js" --include="*.md" . | awk -F: '$2>0' | wc -l
  echo -n "Pilot-ready phrase: "
  grep -c 'Pilot-ready' index.html
  echo ""
  echo "=== STALE 'live on hunter valley' SCAN ==="
  grep -irn 'live on.*hunter valley\|live right now.*hunter\|hunter valley deployment\|hunter valley pilot is currently' --include="*.html" --include="*.md" . || echo "  none ✓"
  echo ""
  echo "=== BUNDLE + ZIP ==="
  ls -la /sessions/admiring-confident-bohr/mnt/outputs/parallaxos-website.bundle
  ls -la /sessions/admiring-confident-bohr/mnt/outputs/parallaxos-website.zip
  echo ""
  echo "=== COMMIT ==="
  git log --oneline -1
} > /sessions/admiring-confident-bohr/mnt/outputs/_repack_out.txt 2>&1

echo done
